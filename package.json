{
  "name": "sharegradient",
  "version": "1.0.0",
  "description": "Framework-agnostic animated shared gradient engine (Canvas + CSS, zero deps)",
  "type": "module",
  "main": "dist/sharegradient.cjs",
  "module": "dist/sharegradient.js",
  "unpkg": "dist/sharegradient.global.js",
  "jsdelivr": "dist/sharegradient.global.js",
  "types": "./dist/sharegradient.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/sharegradient.d.ts",
        "default": "./dist/sharegradient.js"
      },
      "require": {
        "types": "./dist/sharegradient.d.cts",
        "default": "./dist/sharegradient.cjs"
      },
      "default": "./dist/sharegradient.global.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "gradient",
    "animated-gradient",
    "shared-gradient",
    "canvas",
    "css",
    "background",
    "visual-effects",
    "typescript",
    "framework-agnostic",
    "ssr"
  ],
  "author": "MobiWise.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MobiWise-dev/sharegradient.git"
  },
  "bugs": {
    "url": "https://github.com/MobiWise-dev/sharegradient/issues"
  },
  "homepage": "https://github.com/MobiWise-dev/sharegradient#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "canvas": "^3.2.0",
    "jsdom": "^27.4.0",
    "publint": "^0.3.16",
    "rollup": "^4.59.0",
    "terser": "^5.44.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
